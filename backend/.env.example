# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gestion_association?schema=public"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRATION="1h"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_REFRESH_EXPIRATION="7d"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Application
PORT=3000
NODE_ENV="development"

# Multi-tenant
TENANT_HEADER="X-Tenant-ID"

# Notifications
SENDGRID_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR="./uploads"
